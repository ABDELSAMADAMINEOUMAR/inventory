# ==============================================================================
# SmartIMS Backend Environment Configuration (.env)
# ==============================================================================
# To enable real SMTP email delivery (e.g. Gmail, Outlook, SendGrid, AWS SES),
# copy this file to `.env` in the `backend/` folder and fill in your credentials.
# If `.env` or EMAIL_HOST is not provided, Django defaults to Console output!
# ==============================================================================

# SMTP Mail Server Settings (Example: Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Your sender email and App Password (for Gmail, generate an App Password in Account Settings > Security)
EMAIL_HOST_USER=your-company-email@gmail.com
EMAIL_HOST_PASSWORD=your-secret-app-password

# Default From Address displayed in recipient's inbox
DEFAULT_FROM_EMAIL=support@smartims.com
